<Window x:Class="VmMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:VmMonitor"
        Title="Nimbus"
        Width="460" SizeToContent="Height" MaxHeight="620"
        WindowStyle="None" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        </Style>

        <!-- Rounded text inputs -->
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Base button: rounded with hover/press feedback -->
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource ToolBtnBg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ToolBtnHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ToolBtnPressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent button (primary action) -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ToolButton}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat icon-only button: transparent with a subtle square hover -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ToolBtnHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ToolBtnPressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Status pill, colored by state -->
        <Style x:Key="StatusPill" TargetType="Border">
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="9,2"/>
            <Setter Property="Background" Value="#3A3A45"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Active">
                    <Setter Property="Background" Value="#1E7A40"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Idle">
                    <Setter Property="Background" Value="#46505C"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Captured">
                    <Setter Property="Background" Value="#2D6CDF"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Minimized">
                    <Setter Property="Background" Value="#9A6116"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Status dot, colored by state -->
        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Fill" Value="#46505C"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Active">
                    <Setter Property="Fill" Value="#2BBF6A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Idle">
                    <Setter Property="Fill" Value="#6A7480"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Captured">
                    <Setter Property="Fill" Value="#4D8DF0"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Minimized">
                    <Setter Property="Fill" Value="#D08A2E"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Viewing">
                    <Setter Property="Fill" Value="#5AC8FA"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Themed checkbox -->
        <Style x:Key="ThemedCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="box" Width="18" Height="18" CornerRadius="5"
                                    Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                    VerticalAlignment="Center">
                                <Path x:Name="check" Stretch="Uniform" Margin="4,5,4,4"
                                      Data="M0,5 L4,9 L11,0" Stroke="White" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="9,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="box" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pin toggle on each card -->
        <Style x:Key="PinButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Content" Value="&#xE718;"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="ToolTip" Value="Pin to top"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ToolBtnHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                    <Setter Property="Content" Value="&#xE840;"/>
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="ToolTip" Value="Unpin"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- "Mark as idle" toggle on each card: the opposite of pinning. An icon button
             beside the pin, dimmed; sinks the card to the bottom of the list. -->
        <Style x:Key="IdleButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Content" Value="&#xE708;"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Opacity" Value="0.5"/>
            <Setter Property="ToolTip" Value="Mark as idle (send to bottom)"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ToolBtnHover}"/>
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsIdle}" Value="True">
                    <Setter Property="Content" Value="&#xE708;"/>
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="ToolTip" Value="Idle — click to restore"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Rename (pencil) on each card; becomes a checkmark while editing -->
        <Style x:Key="EditButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Content" Value="&#xE70F;"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="ToolTip" Value="Rename"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ToolBtnHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasCustomName}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="ToolTip" Value="Rename"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                    <Setter Property="Content" Value="&#xE73E;"/>
                    <Setter Property="Foreground" Value="#2BBF6A"/>
                    <Setter Property="ToolTip" Value="Save"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Clear-text button shown inside the rename input -->
        <Style x:Key="ClearButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Content" Value="&#xE711;"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="ToolTip" Value="Clear (revert to detected title)"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ToolBtnHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Compact selectable list row -->
        <Style x:Key="RowStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{DynamicResource CardBg}" CornerRadius="8" Padding="10,8"
                                BorderBrush="Transparent" BorderThickness="1.5">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource CardHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource CardSelectedBg}"/>
                            </Trigger>
                            <!-- Highlight the most recently opened/viewed VM. -->
                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource WindowBg}" CornerRadius="8"
            BorderBrush="{DynamicResource WindowBorder}" BorderThickness="1">
        <Grid Margin="12,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Main content: click a row to bring that VM to the foreground -->
            <ListBox Grid.Row="0" x:Name="WindowsList" Background="Transparent" BorderThickness="0"
                     MaxHeight="470"
                     ItemContainerStyle="{StaticResource RowStyle}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     HorizontalContentAlignment="Stretch"
                     PreviewMouseLeftButtonDown="WindowsList_PreviewMouseLeftButtonDown"
                     SelectionChanged="WindowsList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:MonitoredWindow}">
                        <Grid x:Name="CardRoot">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Style="{StaticResource StatusDot}"
                                     VerticalAlignment="Center" Margin="0,0,10,0"
                                     ToolTip="{Binding StatusDescription}"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Title}" FontWeight="Normal" FontSize="11"
                                           Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                                <Grid Height="22" Margin="0,1,0,0">
                                    <TextBlock x:Name="TitleText" Text="{Binding DisplayTitle}"
                                               Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding FullText}"/>
                                    <TextBox x:Name="NameEdit" Visibility="Collapsed"
                                             FontSize="13" Padding="4,0,24,0" VerticalAlignment="Center"
                                             HorizontalAlignment="Left" Width="230"
                                             VerticalContentAlignment="Center"
                                             CharacterCasing="Upper"
                                             Text="{Binding CustomName, UpdateSourceTrigger=PropertyChanged}"
                                             KeyDown="NameEdit_KeyDown" LostFocus="NameEdit_LostFocus"
                                             IsVisibleChanged="NameEdit_IsVisibleChanged"/>
                                    <Button x:Name="ClearEdit" Style="{StaticResource ClearButton}"
                                            Visibility="Collapsed"
                                            HorizontalAlignment="Left" VerticalAlignment="Center"
                                            Margin="206,0,0,0"
                                            Click="ClearEdit_Click"/>
                                </Grid>
                                <TextBlock Text="{Binding PreviousTitle1}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}" Opacity="0.5"
                                           Margin="0,1,0,0" TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding HasPreviousTitle1, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="{Binding PreviousTitle2}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}" Opacity="0.28"
                                           Margin="0,1,0,0" TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding HasPreviousTitle2, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Style="{StaticResource EditButton}"
                                    VerticalAlignment="Center"
                                    Click="EditButton_Click"/>
                            <Button Grid.Column="3" Style="{StaticResource IdleButton}"
                                    VerticalAlignment="Center" Margin="2,0,0,0"
                                    Click="IdleButton_Click"/>
                            <Button Grid.Column="4" Style="{StaticResource PinButton}"
                                    VerticalAlignment="Center" Margin="2,0,0,0"
                                    Click="PinButton_Click"/>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter TargetName="TitleText" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="NameEdit" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <!-- Marked idle: dim the whole card to signal it's de-prioritized. -->
                            <DataTrigger Binding="{Binding IsIdle}" Value="True">
                                <Setter TargetName="CardRoot" Property="Opacity" Value="0.45"/>
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsEditing}" Value="True"/>
                                    <Condition Binding="{Binding HasCustomName}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="ClearEdit" Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Divider -->
            <Border Grid.Row="1" Height="1" Background="{DynamicResource DividerBrush}" Margin="0,8"/>

            <!-- Bottom bar: branding + settings toggle -->
            <Grid Grid.Row="2" Background="Transparent" MouseLeftButtonDown="Header_DragMove">
                <Grid.ToolTip>
                    <ToolTip>
                        <TextBlock x:Name="StatusBar" Text="Starting…"/>
                    </ToolTip>
                </Grid.ToolTip>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Viewbox Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center" Margin="2,0,8,0">
                    <Grid Width="32" Height="32">
                        <Border Background="{DynamicResource AccentBrush}" CornerRadius="4"/>
                        <Canvas Width="32" Height="32">
                            <Ellipse Canvas.Left="5" Canvas.Top="13" Width="12" Height="12" Fill="White"/>
                            <Ellipse Canvas.Left="12" Canvas.Top="8" Width="15" Height="15" Fill="White"/>
                            <Ellipse Canvas.Left="18" Canvas.Top="14" Width="10" Height="10" Fill="White"/>
                            <Border Canvas.Left="6" Canvas.Top="17" Width="20" Height="8" CornerRadius="4" Background="White"/>
                        </Canvas>
                    </Grid>
                </Viewbox>
                <TextBlock Grid.Column="1" Text="Nimbus" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Content="&#xE713;" FontFamily="Segoe MDL2 Assets"
                        Style="{StaticResource IconButton}"
                        FontSize="16" ToolTip="Settings" Click="AdvancedButton_Click"/>
            </Grid>

            <!-- Settings (hidden by default) -->
            <StackPanel Grid.Row="3" x:Name="AdvancedPanel" Visibility="Collapsed" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <Button x:Name="RefreshButton" Content="Refresh"
                            Style="{StaticResource AccentButton}" Padding="14,6" FontSize="11"
                            Margin="0,0,8,0" Click="RefreshButton_Click"/>
                    <Button x:Name="ToggleButton" Content="Pause"
                            Style="{StaticResource ToolButton}" Padding="14,6" FontSize="11"
                            Click="ToggleButton_Click"/>
                    <Button x:Name="ClearMemoryButton" Content="Clear memory"
                            Style="{StaticResource ToolButton}" Padding="14,6" FontSize="11"
                            Margin="8,0,0,0" ToolTip="Forget the saved last-known state for every window"
                            Click="ClearMemoryButton_Click"/>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Filter" Foreground="{DynamicResource TextMuted}"
                               VerticalAlignment="Center" Margin="0,0,12,8"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="FilterBox" Margin="0,0,0,8"
                             HorizontalAlignment="Left" Width="240" VerticalAlignment="Center"
                             ToolTip="Match window title or process name (blank = all)" Text="msrdc"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Update status every" Foreground="{DynamicResource TextMuted}"
                               VerticalAlignment="Center" Margin="0,0,12,8"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox x:Name="IntervalBox" Width="56" Text="60" VerticalAlignment="Center"
                                 ToolTip="How often window states are scanned"/>
                        <TextBlock Text="seconds" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Refresh title every" Foreground="{DynamicResource TextMuted}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                        <TextBox x:Name="UpdateIntervalBox" Width="56" Text="10" VerticalAlignment="Center"
                                 ToolTip="How often chat titles are re-read"/>
                        <TextBlock Text="seconds" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Ignore titles" Foreground="{DynamicResource TextMuted}"
                               VerticalAlignment="Center" Margin="0,8,12,0"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="IgnoreBox" Margin="0,8,0,0"
                             HorizontalAlignment="Left" Width="240" VerticalAlignment="Center"
                             ToolTip="Comma-separated headings to ignore as chat titles (e.g. sessions)"
                             Text="sessions"/>
                </Grid>

                <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="0,14"/>

                <CheckBox x:Name="StartupCheck" Style="{StaticResource ThemedCheck}"
                          Content="Start with Windows" Click="StartupCheck_Click"/>

                <TextBlock x:Name="FooterText" Margin="0,16,0,0" FontSize="11"
                           Foreground="{DynamicResource TextMuted}"
                           HorizontalAlignment="Center" TextAlignment="Center"/>
            </StackPanel>

            <!-- First-run initializing view -->
            <Border Grid.Row="0" Grid.RowSpan="4" x:Name="InitOverlay"
                    Background="{DynamicResource WindowBg}" CornerRadius="11" MinHeight="180">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Ellipse Width="34" Height="34" Stroke="{DynamicResource AccentBrush}" StrokeThickness="3"
                             StrokeDashArray="4 2" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="InitSpin"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="InitSpin"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360" Duration="0:0:1.1"
                                                         RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <TextBlock Text="Nimbus" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center" Margin="0,14,0,2"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
